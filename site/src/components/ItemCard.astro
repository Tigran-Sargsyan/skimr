---
import type { CollectionEntry } from 'astro:content';
import ThemeChip from './ThemeChip.astro';

interface Props {
  item: CollectionEntry<'items'>;
  variant?: 'full' | 'compact';
}

const { item, variant = 'full' } = Astro.props;
const data = item.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const itemHref = `${base}/items/${item.slug}`;

const publishedDate = new Date(data.published_at);
const dateLabel = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<a class="item-card" href={itemHref}>
  <h2 class="item-hook">{data.hook}</h2>
  {variant === 'full' && <p class="item-tldr">{data.tldr}</p>}
  <div class="item-meta">
    <span>{data.author}</span>
    <span class="item-meta-divider">{dateLabel}</span>
    <span class="item-meta-divider"><ThemeChip theme={data.primary_theme} /></span>
  </div>
</a>
