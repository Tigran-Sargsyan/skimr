---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = await getCollection('items');

interface Bucket {
  name: string;
  slug: string;
  count: number;
}
const bySlug = new Map<string, Bucket>();
for (const item of all) {
  const key = item.data.source_slug;
  const existing = bySlug.get(key);
  if (existing) existing.count += 1;
  else bySlug.set(key, { name: item.data.author, slug: key, count: 1 });
}
const sources = [...bySlug.values()].sort((a, b) => b.count - a.count);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="skimr — Sources">
  <h1>Sources</h1>
  {sources.length === 0 ? (
    <p class="empty-state">No sources have produced items yet.</p>
  ) : (
    <ul class="source-list">
      {sources.map((s) => (
        <li>
          <a href={`${base}/sources/${s.slug}`}>{s.name}</a>
          <span class="count">{s.count} {s.count === 1 ? 'item' : 'items'}</span>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
